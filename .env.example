# ═══════════════════════════════════════════════════
# NextBol AI — Environment Variables
# INSTRUCTIONS: Rename this file to .env.local
# Then fill in each value from the services below
# ═══════════════════════════════════════════════════

# ── SUPABASE ──
# 1. Go to supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── OPENAI ──
# 2. Go to platform.openai.com → API Keys → Create
OPENAI_API_KEY=your_openai_api_key_here

# ── STRIPE ──
# 3. Go to dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# 4. Create products in Stripe → Products → copy Price IDs
STRIPE_PRICE_CREATOR=your_creator_price_id_here
STRIPE_PRICE_AGENCY=your_agency_price_id_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# ── ADMIN PANEL ACCESS (change these!) ──
ADMIN_EMAIL=admin@nextbol.com
ADMIN_PASSWORD=NextBol2026Secure!
ADMIN_SECRET=change_this_to_random_32_char_string

# ── APP ──
NEXT_PUBLIC_APP_URL=https://nextbol-ai-claud.vercel.app
